PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hirenest
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Admin Configurations
COMPANY_EMAIL=info@hirenestplacement.com
ADMIN_PASSWORD=your_secure_admin_password
JWT_SECRET=your_secure_jwt_secret_key_here

# Brevo (transactional email HTTP API) configuration
# Falls back to logging mock alerts if empty. This replaces SMTP because Render's
# free tier blocks outbound SMTP ports (25, 465, 587) — see backend/utils/emailService.js
# Get your API key from Brevo: Settings -> SMTP & API -> API Keys
BREVO_API_KEY=your_brevo_api_key
# Must be verified in Brevo under Senders, Domains & Dedicated IPs -> Senders
SENDER_EMAIL=info@hirenestplacement.com
